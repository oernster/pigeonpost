{
  "$schema": "https://wails.io/schemas/config.v2.json",
  "name": "pigeonpost",
  "outputfilename": "PigeonPost",
  "frontend:install": "npm install",
  "frontend:build": "npm run build",
  "frontend:dev:watcher": "npm run dev",
  "frontend:dev:serverUrl": "auto",
  "author": {
    "name": "Oliver Ernster",
    "email": "oernster@codecrafter.uk"
  },
  "info": {
    "protocols": [
      {
        "scheme": "mailto",
        "description": "Email address links",
        "role": "Editor"
      }
    ],
    "fileAssociations": [
      {
        "ext": "eml",
        "name": "Email message",
        "description": "RFC 822 email message file",
        "iconName": "eml",
        "role": "Viewer"
      }
    ]
  }
}
