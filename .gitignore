# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov
*.cov
# Stray ad-hoc coverage profile from a manual `go test -coverprofile=...`
# (test.ps1 itself writes to %TEMP%, never the repo)
$coverProfile

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# Editor/IDE
# .idea/
# .vscode/
.claude/

# Node / frontend
node_modules/
frontend/dist/
# Vitest coverage output
frontend/coverage/
# Wails npm dependency-hash cache (regenerated on every build)
frontend/package.json.md5

# Wails build output
build/bin/

# macOS DMG build output
dist-dmg/

# Flatpak build artefacts (regenerated by build_flatpak.sh)
.flatpak-build/
.flatpak-repo/
.flatpak-builder/
packaging/
*.flatpak
uk.codecrafter.PigeonPost.yml
build/linux/

# Local scratch
NOTES.md
FRONTEND_PLAN.md
REMAINING_REFACTOR.md
*.db
*.db-*
